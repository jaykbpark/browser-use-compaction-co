# Browserbase is optional for local development.
# If unset, scripts use a local Playwright Chromium browser.
BROWSERBASE_CONNECT_URL=

# Keep these for the Browserbase team if they implement session creation.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional LLM planner keys for later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

RUNS_DIR=runs
