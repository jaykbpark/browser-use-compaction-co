# Browserbase is optional for local development.
# If unset, scripts use a local Playwright Chromium browser.
# Browserbase can infer the project from the API key in the default setup.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional advanced path if the event gives you a raw CDP connect URL.
BROWSERBASE_CONNECT_URL=

# Optional LLM planner keys for later.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=

# Optional Arize AX tracing for eval and live BrowserGym runs.
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=browserdelta-hackathon

RUNS_DIR=runs
