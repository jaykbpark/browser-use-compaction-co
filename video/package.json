{
  "name": "browserdelta-remotion-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preview": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts BrowserDeltaDemo out/browserdelta-demo.mp4 --codec=h264 --crf=18",
    "poster": "remotion still src/index.ts BrowserDeltaDemo out/poster.png --frame=120",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "latest",
    "react": "latest",
    "react-dom": "latest",
    "remotion": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
